# Copy this to .env and adjust if your local setup differs.
# Defaults in config.py already match a standard local LiteLLM + Ollama
# setup, so an .env file is only needed if you've changed something.

LITELLM_BASE_URL=http://localhost:4000
JOB_TAILOR_MODEL=qwen-coder-14b
LITELLM_API_KEY=sk-local-not-needed
JOB_TAILOR_TEMPERATURE=0.4
JOB_TAILOR_MAX_TOKENS=2000
